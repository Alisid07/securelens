# SecureLens environment configuration
# Copy this file to .env, fill in real values, and NEVER commit the result to git.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Supported values: mock (no API key needed) | anthropic | openai
SECURELENS_LLM_PROVIDER=mock

# Anthropic API key — required when SECURELENS_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key — required when SECURELENS_LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Model name sent to the selected provider
# Anthropic default: claude-sonnet-4-6
# OpenAI default:    gpt-4o-mini
SECURELENS_LLM_MODEL=claude-sonnet-4-6

# ── LLM behaviour ─────────────────────────────────────────────────────────────
# Seconds to wait for an LLM response before raising LLMTimeoutError
SECURELENS_LLM_TIMEOUT=30

# Number of retry attempts on transient errors (timeout, rate-limit)
SECURELENS_LLM_MAX_RETRIES=3

# ── Scanner behaviour ─────────────────────────────────────────────────────────
# Maximum file size (bytes) accepted for scanning; default 1 MiB (1048576)
SECURELENS_MAX_FILE_SIZE=1048576

# Optional: override the directory that contains YAML rule files
# Leave blank to use the built-in securelens/rules/ directory
SECURELENS_RULES_DIR=
